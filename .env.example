# agent-mail configuration
# Copy to .env and fill in your values

# MCP server listen address
ADDR=:8080

# SQLite database path
DB_PATH=/data/agent-mail.db

# Legacy MCP authentication (optional, overrides user token system)
# AUTH_HEADER=X-Agent-Mail-Token
# AUTH_TOKEN=legacy-token-here

# Admin panel password (auto-generated if not set)
# ADMIN_PASSWORD=your-admin-password
